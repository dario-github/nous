        <mxCell id="title" value="&lt;b&gt;Figure 1.&lt;/b&gt; Three-layer composable safety gate architecture. Each tool call traverses layers sequentially; early exits reduce cost." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="150" y="360" width="800" height="30" as="geometry"/>
